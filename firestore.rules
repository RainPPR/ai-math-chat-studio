rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidUserSettings() {
      return hasOnlyAllowedFields(['provider', 'model', 'systemPrompt', 'thinkingLevel', 'reasoningEffort', 'geminiApiKey', 'customBaseUrl', 'customApiKey', 'customModel', 'customParameters', 'temperature', 'topP', 'maxTokens', 'extraBody', 'memories', 'renderThinkingAsMarkdown', 'autoScroll']) &&
             (request.resource.data.provider is string || !('provider' in request.resource.data)) &&
             (request.resource.data.model is string || !('model' in request.resource.data)) &&
             (request.resource.data.systemPrompt is string || !('systemPrompt' in request.resource.data)) &&
             (request.resource.data.thinkingLevel is string || !('thinkingLevel' in request.resource.data)) &&
             (request.resource.data.reasoningEffort is string || !('reasoningEffort' in request.resource.data)) &&
             (request.resource.data.geminiApiKey is string || !('geminiApiKey' in request.resource.data)) &&
             (request.resource.data.customBaseUrl is string || !('customBaseUrl' in request.resource.data)) &&
             (request.resource.data.customApiKey is string || !('customApiKey' in request.resource.data)) &&
             (request.resource.data.customModel is string || !('customModel' in request.resource.data)) &&
             (request.resource.data.customParameters is list || !('customParameters' in request.resource.data)) &&
             (request.resource.data.temperature is number || !('temperature' in request.resource.data)) &&
             (request.resource.data.topP is number || !('topP' in request.resource.data)) &&
             (request.resource.data.maxTokens is number || !('maxTokens' in request.resource.data)) &&
             (request.resource.data.extraBody is string || !('extraBody' in request.resource.data)) &&
             (request.resource.data.renderThinkingAsMarkdown is bool || !('renderThinkingAsMarkdown' in request.resource.data)) &&
             (request.resource.data.autoScroll is bool || !('autoScroll' in request.resource.data)) &&
             (request.resource.data.memories is list || !('memories' in request.resource.data));
    }

    function isValidChatSession() {
      return hasOnlyAllowedFields(['id', 'uid', 'title', 'messages', 'createdAt', 'updatedAt']) &&
             request.resource.data.id is string &&
             request.resource.data.uid is string &&
             request.resource.data.title is string && request.resource.data.title.size() <= 200 &&
             request.resource.data.messages is list &&
             request.resource.data.createdAt is string &&
             request.resource.data.updatedAt is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserSettings();
      allow update: if isOwner(userId) && isValidUserSettings();
    }

    match /sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && isValidChatSession();
      allow update: if isDocOwner() && uidNotModified() && isValidChatSession();
      allow delete: if isDocOwner();
    }
  }
}
